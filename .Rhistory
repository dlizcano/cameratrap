)
summary(umf)
plot (umf)
# detection first, occupancy next
fm0 <- occu(~1 ~1, umf, starts=c(1,1)) #, starts=c(1,1)) # Null model
fm1 <- occu(~ scale(rain) ~ 1, umf, starts=c(1,1)) # rain explaining detection
# detection first, occupancy next
fm0 <- occu(~1 ~1, umf, starts=c(1,1)) #, starts=c(1,1)) # Null model
fm1 <- occu(~ scale(rain) ~ 1, umf, starts=c(1,1,1)) # rain explaining detection
fm1_1 <- occu(~ scale(rain +I(rain^2)) ~ 1, umf, starts=c(1,1,1))
models1 <- fitList( # here we put names to the models
'p(.)psi(.)'                        = fm0,
'p(rain)psi(.)'                     = fm1,
'p(rain^2)psi(.)'                   = fm1_1
)
modSel(models1) # model selection procedure
# detection first, occupancy next
fm0 <- occu(~1 ~1, umf, starts=c(0,0)) #, starts=c(1,1)) # Null model
fm1 <- occu(~ scale(rain) ~ 1, umf, starts=c(0,0,0)) # rain explaining detection
fm1_1 <- occu(~ scale(rain +I(rain^2)) ~ 1, umf, starts=c(0,0,0))
